{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BehaviorLossArtifact",
  "description": "Schema for Behavior Loss learned artifact, containing delta metrics and review-level behavior loss calculations.",
  "type": "object",
  "patternProperties": {
    "^.+$": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "description": "Unique user identifier"
        },
        "review_id": {
          "type": "string",
          "description": "Unique review identifier"
        },
        "text_delta": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Cosine distance between predicted and actual review text embeddings"
        },
        "theme_delta": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Theme prediction error (1 - recall@max(3,k))"
        },
        "overall_behavior_loss": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Weighted combination of text_delta and theme_delta"
        },
        "metrics": {
          "type": "object",
          "properties": {
            "rating_score": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "sentiment_score": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@1": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@3": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@5": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@max(3,k)": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@max(3,k)_threshold_0.8": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "recall@max(3,k)_threshold_0.85": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "overall_accuracy": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "num_actual_themes": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": ["overall_accuracy"],
          "additionalProperties": true
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "description": "SGO iteration number when this loss was calculated"
        },
        "improved": {
          "type": "boolean",
          "description": "Whether this review improved from previous iteration"
        }
      },
      "required": ["user_id", "review_id", "text_delta", "theme_delta", "overall_behavior_loss", "metrics"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

