{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewTopicClassificationArtifact",
  "description": "Schema for Review Topic Classification artifact, containing identified themes and token probabilities for each review.",
  "type": "object",
  "properties": {
    "review_id": {
      "type": "string",
      "description": "Unique identifier for the review",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "description": "User ID who wrote the review",
      "minLength": 1
    },
    "review": {
      "type": "string",
      "description": "The review text",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "description": "Product category",
      "minLength": 1
    },
    "identified_themes": {
      "type": "array",
      "description": "List of themes identified by the LLM (from identified_themes field in response)",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "theme_token_probabilities": {
      "type": "object",
      "description": "Dictionary mapping each identified theme to its token probability",
      "patternProperties": {
        "^.+$": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "sentiment": {
      "type": "string",
      "description": "Sentiment classification",
      "enum": ["Positive", "Negative", "Neutral"]
    },
    "rating": {
      "type": ["number", "null"],
      "description": "Product rating (if available)"
    },
    "asin": {
      "type": ["string", "null"],
      "description": "Product ASIN (if available)"
    },
    "timestamp": {
      "type": ["string", "null"],
      "description": "Review timestamp (if available)"
    },
    "error": {
      "type": ["string", "null"],
      "description": "Error message if processing failed"
    }
  },
  "required": ["review_id", "user_id", "review", "category", "sentiment"]
}
