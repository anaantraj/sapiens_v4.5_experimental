{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SimulationResultsArtifact",
  "description": "Schema for Simulation Results learned artifact, containing comprehensive simulation data with extensive metadata.",
  "type": "object",
  "patternProperties": {
    "^.+$": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "string",
          "description": "Unique user identifier"
        },
        "num_reviews_of_user": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of reviews by this user"
        },
        "tribe_name": {
          "type": "string",
          "description": "Name of the tribe (micro cluster persona)"
        },
        "tribe_id": {
          "type": "string",
          "description": "Tribe identifier (micro cluster ID)"
        },
        "num_users_in_tribe": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of users in this tribe"
        },
        "cluster_name": {
          "type": "string",
          "description": "Cluster/Segment name (macro cluster)"
        },
        "cluster_id": {
          "type": "string",
          "description": "Cluster/Segment identifier"
        },
        "num_tribes_in_cluster": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of tribes in this cluster"
        },
        "stimulus_product_id": {
          "type": "string",
          "description": "Product ID (ASIN or product identifier)"
        },
        "stimulus_product_description": {
          "type": "string",
          "description": "Product description"
        },
        "real_review": {
          "type": "string",
          "description": "Actual review text written by the user"
        },
        "real_review_embedding": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Embedding vector for the real review"
        },
        "rating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "description": "Actual rating given by the user"
        },
        "real_topic_probabilities": {
          "type": "object",
          "patternProperties": {
            "^.+$": {
              "type": "object",
              "properties": {
                "probability": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Topic probability score"
                },
                "embedding": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "description": "Embedding vector for this topic"
                }
              },
              "required": ["probability"],
              "additionalProperties": false
            }
          },
          "description": "Topic probabilities with embeddings for real review"
        },
        "synthetic_review": {
          "type": "string",
          "description": "Synthetic review text generated by the model"
        },
        "synthetic_review_embedding": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "description": "Embedding vector for the synthetic review"
        },
        "synthetic_topic_probabilities": {
          "type": "object",
          "patternProperties": {
            "^.+$": {
              "type": "object",
              "properties": {
                "probability": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Topic probability score"
                },
                "embedding": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "description": "Embedding vector for this topic"
                }
              },
              "required": ["probability"],
              "additionalProperties": false
            }
          },
          "description": "Topic probabilities with embeddings for synthetic review"
        },
        "sentiment_predicted": {
          "type": "string",
          "enum": ["Positive", "Negative", "Neutral"],
          "description": "Predicted sentiment"
        },
        "rating_predicted": {
          "type": "number",
          "minimum": 1,
          "maximum": 5,
          "description": "Predicted rating"
        }
      },
      "required": [
        "user_id",
        "num_reviews_of_user",
        "tribe_name",
        "tribe_id",
        "num_users_in_tribe",
        "cluster_name",
        "cluster_id",
        "num_tribes_in_cluster",
        "stimulus_product_id",
        "stimulus_product_description",
        "real_review",
        "real_review_embedding",
        "rating",
        "real_topic_probabilities",
        "synthetic_review",
        "synthetic_review_embedding",
        "synthetic_topic_probabilities",
        "sentiment_predicted",
        "rating_predicted"
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

